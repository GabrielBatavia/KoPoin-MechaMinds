{
  "expo": {
    "name": "Kopoin",
    "slug": "kopoin-mvp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Kopoin memakai kamera untuk memindai QR transaksi demo produk koperasi.",
          "recordAudioAndroid": false
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kopoin memakai kamera untuk memindai QR transaksi demo produk koperasi."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "CAMERA",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.anonymous.kopoinmvp"
    },
    "splash": {
      "image": "./src/assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
